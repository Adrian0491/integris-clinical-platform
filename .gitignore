# =============================================================================
# CDTool — Git ignore rules
# =============================================================================

# ── Secrets & credentials ────────────────────────────────────────────────────
# NEVER commit these files. Rotate credentials immediately if exposed.
.env
.env.local
.env.*.local
backend/.env
*.pem
*.key
*.p12
*.pfx

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover
.hypothesis/
venv/
.venv/
env/
.env/
ENV/

# ── Node / Angular ────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.angular/

# ── Storage / uploads ─────────────────────────────────────────────────────────
# The storage/ dir holds uploaded clinical data files — never commit those.
# Do NOT use *.csv or *.json here: those patterns break package.json,
# angular.json, tsconfig.json, and every other JSON config file.
storage/
mock_data/

# ── Editors & OS ──────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but exclude local override
docker-compose.override.yml

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations, but exclude local DB snapshots
*.db

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/

# ── Stale / legacy files (pre-rewrite) ────────────────────────────────────────
# These are old files that predate the CDTool FastAPI/Angular rewrite.
# They are excluded so they don't clutter the repo.
bk/
frontend/test_tiral_mock/
frontend/ts/
main_validators.py
cleanup.sh
__init__.py
/package.json
/requirements.txt

# ── Terraform ─────────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
# terraform.tfvars can contain db_password; pass via TF_VAR_db_password env var
# .terraform.lock.hcl IS committed (provider version pinning)

# ── VS Code local-only settings ───────────────────────────────────────────────
# Commit extensions.json/launch.json/tasks.json, but not mcp.json
frontend/.vscode/mcp.json
.vscode/
