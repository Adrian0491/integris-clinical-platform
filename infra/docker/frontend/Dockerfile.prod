# =============================================================================
# Frontend — multi-stage production image
# Stage 1: Node 22 → ng build --configuration production
# Stage 2: nginx:alpine serving the static bundle
# =============================================================================

# ── Stage 1: Angular build ────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Install deps first (layer cache — only re-runs when package*.json changes)
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --ignore-scripts

# Copy source and build
COPY frontend/ .
RUN npx ng build --configuration production

# ── Stage 2: nginx runtime ────────────────────────────────────────────────────
FROM nginx:1.27-alpine AS runtime

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy our custom config
COPY infra/docker/frontend/nginx.conf /etc/nginx/nginx.conf

# Copy the Angular build output
# ng build outputs to dist/<project-name>/browser with Angular 17+
COPY --from=builder /app/dist/frontend/browser /usr/share/nginx/html

# nginx needs write access to /tmp for pid file (non-root compatible)
RUN chown -R nginx:nginx /usr/share/nginx/html /var/cache/nginx /var/log/nginx && \
    touch /tmp/nginx.pid && chown nginx:nginx /tmp/nginx.pid

USER nginx

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- http://localhost:8080/health || exit 1

CMD ["nginx", "-g", "daemon off;"]
