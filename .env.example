# =================================================================
# CDTool — local development environment template
#
# 1. Copy this file:   cp .env.example .env
# 2. Generate RSA keys: python backend/scripts/generate_keys.py
#    Paste the output into JWT_PRIVATE_KEY and JWT_PUBLIC_KEY below.
# 3. Set a strong SECRET_KEY (openssl rand -hex 32)
# =================================================================

# PostgreSQL
POSTGRES_USER=cdtool
POSTGRES_PASSWORD=cdtool_dev
POSTGRES_DB=cdtool

# Application URLs (used inside Docker; override for local dev)
DATABASE_URL=postgresql://cdtool:cdtool_dev@localhost:5432/cdtool
TEST_DATABASE_URL=postgresql://cdtool:cdtool_dev@localhost:5432/cdtool_test
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# Storage (local = filesystem, gcs = Google Cloud Storage)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# JWT RS256 — paste the output of backend/scripts/generate_keys.py here
# Keys must be single-line PEM with literal \n for newlines.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# HMAC secret for electronic signatures (21 CFR Part 11)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-minimum-256-bits

# App
DEBUG=true
ENVIRONMENT=development
