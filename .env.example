# =================================================================
# Integris Clinical Platform — local development environment template
#
# 1. Copy this file:   cp .env.example .env
# 2. Generate RSA keys: python backend/scripts/generate_keys.py
#    (or: make keys)
# 3. Set a strong SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 4. Optional: set ANTHROPIC_API_KEY to enable AI-powered endpoints
# =================================================================

# PostgreSQL
POSTGRES_USER=cdtool
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=cdtool

# Application URLs (used inside Docker; override for local dev)
# Replace REPLACE_WITH_STRONG_PASSWORD with the same value as POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://cdtool:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/cdtool
TEST_DATABASE_URL=postgresql://cdtool:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/cdtool_test
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# Storage (local = filesystem, gcs = Google Cloud Storage)
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
GCS_BUCKET_NAME=
GCS_PROJECT_ID=

# JWT RS256 — paste the output of backend/scripts/generate_keys.py here
# Keys must be single-line PEM with literal \n for newlines.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# HMAC secret for electronic signatures (21 CFR Part 11)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_OUTPUT_OF__python -c "import secrets; print(secrets.token_hex(32))"

# AI layer (Anthropic Claude API)
# Required to use /api/v1/ai/* endpoints. Leave blank to disable AI features.
# Never commit a real key — use GCP Secret Manager in production (see TODO-AI-007).
ANTHROPIC_API_KEY=

# CORS — Landing page origin
# Set to the GCS bucket URL or custom domain in production.
# Default allows the local npx-serve preview server (port 5500).
LANDING_ORIGIN=http://localhost:5500

# App
DEBUG=true
ENVIRONMENT=development
